ENV=development
DJANGO_SETTINGS_MODULE=api.settings.dev
SECRET_KEY=django-insecure-local-key

# Local DB (SQLite or Postgres)
DATABASE_URL=sqlite:///db.sqlite3
PGHOST=localhost
PGDATABASE=my_local_db
PGUSER=postgres
PGPASSWORD=password
PGPORT=5432
PGSSLMODE=disable

FRONTEND_URL=http://127.0.0.1:5173


# This copies the .env.development in to a .env file and settings load load_dotenv().
# copy .env.development .env
# python manage.py runserver